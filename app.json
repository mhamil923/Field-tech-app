{
  "expo": {
    "name": "field-tech-app",
    "slug": "field-tech-app-v2",
    "owner": "first-class-glass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-1024.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "buildNumber": "157",
      "supportsTablet": true,
      "bundleIdentifier": "com.firstclassglass.fieldtech",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "We use the camera to capture job site photos and signatures for work orders.",
        "NSPhotoLibraryUsageDescription": "We access your photo library so you can upload job photos and signed documents.",
        "NSPhotoLibraryAddUsageDescription": "We save signed PDFs or images to your library when you export them.",
        "LSApplicationQueriesSchemes": [
          "comgooglemaps"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsArbitraryLoadsInWebContent": true,
          "NSExceptionDomains": {
            "fcgg.us-east-2.elasticbeanstalk.com": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "package": "com.firstclassglass.fieldtech",
      "versionCode": 101,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-foreground-1024.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-dev-client"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://fcgg.us-east-2.elasticbeanstalk.com",
      "eas": {
        "projectId": "00e5d719-5017-4c75-ad1e-a536447654c0"
      }
    },
    "runtimeVersion": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "url": "https://u.expo.dev/00e5d719-5017-4c75-ad1e-a536447654c0"
    }
  }
}
