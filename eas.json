{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "developmentClient": true,
      "channel": "development",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "NPM_CONFIG_FUND": "false",
        "NPM_CONFIG_AUDIT": "false",
        "EXPO_NO_TELEMETRY": "1"
      },
      "ios": {
        "simulator": true,
        "image": "macos-14-xcode-15.4",
        "resourceClass": "medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "NPM_CONFIG_FUND": "false",
        "NPM_CONFIG_AUDIT": "false",
        "EXPO_NO_TELEMETRY": "1"
      },
      "ios": {
        "credentialsSource": "remote",
        "image": "macos-14-xcode-15.4",
        "resourceClass": "medium"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "NPM_CONFIG_FUND": "false",
        "NPM_CONFIG_AUDIT": "false",
        "EXPO_NO_TELEMETRY": "1"
      },
      "ios": {
        "credentialsSource": "remote",
        "image": "macos-14-xcode-15.4",
        "resourceClass": "medium"
      }
    }
  },
  "submit": {
    "production": {
      "ios": { "appleTeamId": "75F4VG5YNK" }
    }
  }
}
